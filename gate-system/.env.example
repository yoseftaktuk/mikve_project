COMPOSE_PROJECT_NAME=gate-system

# Public
PUBLIC_HTTP_PORT=80

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gate
POSTGRES_USER=gate
POSTGRES_PASSWORD=gate_password_change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
# Published on the LAN so the Pi hardware-service can publish events (split deploy).
REDIS_LAN_PORT=6379

# Split deploy (server compose): LAN IP of the Raspberry Pi running hardware-service.
# Example: EDGE_HARDWARE_HOST=192.168.1.50
EDGE_HARDWARE_HOST=

