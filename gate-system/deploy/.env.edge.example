# Copy to gate-system/.env.edge on the Raspberry Pi (do not commit real IPs/secrets).
# Used with: docker compose -f deploy/docker-compose.edge.yml --project-directory . --env-file .env.edge up -d --build

COMPOSE_PROJECT_NAME=gate-system-edge
PUBLIC_HTTP_PORT=80
HARDWARE_HTTP_PORT=8000

# LAN IP of the backend PC running deploy/docker-compose.server.yml
SERVER_LAN_IP=192.168.1.10
