SERVICE_NAME=hardware-service
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Single-host Docker: redis://redis:6379/0
# Split deploy (Pi → server): redis://<SERVER_LAN_IP>:6379/0
REDIS_URL=redis://192.168.150.196:6379/0

# Hardware mode: mock | rpi
HARDWARE_MODE=rpi

# Door relay (BCM pin 22 = physical pin 15)
DOOR_RELAY_GPIO_PIN=22
# false = door open drives pin LOW (0V). Idle keeps pin HIGH.
# true  = door open drives pin HIGH (only for active-HIGH relays).
DOOR_RELAY_ACTIVE_HIGH=false
# Door open duration is configured in access-control-service (.env DOOR_UNLOCK_SECONDS)

# RFID reader (serial USB)
RFID_SERIAL_PORT=
RFID_BAUDRATE=9600

# Coin acceptor pulse input (BCM pin 17)
COIN_ACCEPTOR_GPIO_PIN=17
